# ============================================================
# Gorilla Rental AI — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.
# ============================================================

# Anthropic (Claude AI)
ANTHROPIC_KEY=

# GoHighLevel CRM
GHL_API_KEY=
GHL_LOCATION_ID=
GHL_API_URL=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
GHL_MAIN_PHONE=+1XXXXXXXXXX
GHL_CHIP_PHONE=+1XXXXXXXXXX

# Booqable (rental software)
BOOQABLE_API_KEY=
BOOQABLE_URL=https://YOUR-SUBDOMAIN.booqable.com/api/boomerang

# Stripe (payments)
STRIPE_KEY=sk_live_...

# Microsoft 365 / Azure (for Chip email via Outlook)
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=
CHIP_EMAIL=
CHIP_PASSWORD=

# Telegram bot (Andrei notifications)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Maps (distance/geocoding)
GOOGLE_MAPS_API_KEY=

# PostgreSQL (optional — falls back to JSON files)
DATABASE_URL=

# Server
PORT=3000
NODE_ENV=production
